# KΛIROS Bot — Environment Variables
# Copy this to .env and fill in your values

# Optional: Last.fm API key for artist trend data
# Get one free at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Output directory for generated audio files (default: ./output)
KAIROS_OUTPUT_DIR=output

# MusicGen model size: small | medium | large | melody
# medium is best balance of quality vs speed
MUSICGEN_MODEL=facebook/musicgen-medium

# Duration of each generated clip in seconds (15-30 recommended)
MUSICGEN_DURATION=30

# Base URL for your SoundCloud profile (used in site links)
SOUNDCLOUD_BASE_URL=https://soundcloud.com/kairos-transmissions/

# Email notifications — daily prompt delivery
# Use your Gmail address + an App Password (NOT your real password)
# Get App Password: myaccount.google.com → Security → 2-Step Verification → App Passwords
GMAIL_USER=kairos.transmissions@gmail.com
GMAIL_APP_PASSWORD=
